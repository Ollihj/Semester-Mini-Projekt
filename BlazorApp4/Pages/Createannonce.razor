@page "/createannonce"
@using Core.Models
@using BlazorApp4.Service
@using Blazored.LocalStorage
@inject IItemService itemService
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage

<PageTitle>Opret ny annonce</PageTitle>

<div class="form-container">
    <div class="form-header">
        <h2>Opret ny annonce</h2>
        <button class="close-btn" @onclick="GoBack">✕</button>
    </div>

    <div class="form-group">
        <label for="titel">Titel <span class="required">*</span></label>
        <input id="titel" @bind="newAnnonce.Titel" class="form-control" placeholder="F.eks. iPhone 12 64GB" />
    </div>

    <div class="form-group">
        <label for="description">Beskrivelse <span class="required">*</span></label>
        <textarea id="description" @bind="newAnnonce.Description" class="form-control" placeholder="Beskriv varen i detaljer..." rows="5"></textarea>
    </div>

    <div class="form-row">
        <div class="form-group">
            <label for="pris">Pris (kr) <span class="required">*</span></label>
            <input id="pris" type="number" @bind="newAnnonce.pris" class="form-control" placeholder="0" />
        </div>
        <div class="form-group">
            <label for="kategori">Kategori <span class="required">*</span></label>
            <select id="kategori" @bind="kategori" class="form-control">
                <option value="">Vælg kategori</option>
                <option value="Elektronik">Elektronik</option>
                <option value="Møbler">Møbler</option>
                <option value="Tøj">Tøj</option>
                <option value="Biler">Biler</option>
                <option value="Sport">Sport</option>
                <option value="Hjem">Hjem & Have</option>
                <option value="Andet">Andet</option>
            </select>
        </div>
    </div>

    <div class="form-group">
        <label for="lokation">Lokation <span class="required">*</span></label>
        <select id="lokation" @bind="lokation" class="form-control">
            <option value="">Vælg lokation</option>
            <option value="Bygning A">Bygning A</option>
            <option value="Bygning B">Bygning B</option>
            <option value="Bygning C">Bygning C</option>
            <option value="Lager">Lager</option>
        </select>
    </div>

    <div class="form-group">
        <label for="billede">Billede URL (valgfri)</label>
        <input id="billede" @bind="billedeUrl" class="form-control" placeholder="https://example.com/image.jpg" />
        <small>Du kan tilføje et link til et billede af varen</small>
    </div>

    <div class="form-actions">
        <button class="btn btn-primary" @onclick="async () => await CreateAnnonce()">Opret annonce</button>
        <button class="btn btn-secondary" @onclick="GoBack">Annuller</button>
    </div>
</div>

@code {
    private annoncer newAnnonce = new annoncer();
    private string kategori = "";
    private string lokation = "";
    private string billedeUrl = "";
    private Core.Models.bruger? currentUser;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await LocalStorage.GetItemAsync<Core.Models.bruger>("user");
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
    }

    private async Task CreateAnnonce()
    {
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        newAnnonce.oprettet = DateTime.Now;
        newAnnonce.annonceId = Guid.NewGuid().ToString();
        newAnnonce.kategori = kategori;
        newAnnonce.status = "Aktiv";
        newAnnonce.brugerID = currentUser.brugerID;

        await itemService.Add(newAnnonce);

        Navigation.NavigateTo("/");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
}
