@page "/register"
@using BlazorApp4.Service
@inject NavigationManager Navigation
@inject LoginService LoginService

<PageTitle>Opret bruger</PageTitle>

<div class="register-container" style="max-width: 400px; margin: 50px auto; padding: 20px;">
    <h2 style="text-align: center; margin-bottom: 30px;">Opret ny bruger</h2>

    <div class="form-group mb-3">
        <label for="username">Brugernavn</label>
        <input id="username" 
               type="text" 
               class="form-control" 
               @bind="username" 
               placeholder="Vælg et brugernavn" />
    </div>

    <div class="form-group mb-3">
        <label for="password">Adgangskode</label>
        <input id="password" 
               type="password" 
               class="form-control" 
               @bind="password" 
               placeholder="Vælg en adgangskode" />
    </div>

    <div class="form-group mb-3">
        <label for="confirmPassword">Bekræft adgangskode</label>
        <input id="confirmPassword" 
               type="password" 
               class="form-control" 
               @bind="confirmPassword" 
               placeholder="Gentag adgangskode" />
    </div>

    @if (!string.IsNullOrEmpty(errorText))
    {
        <div class="alert alert-danger" role="alert">
            ⚠️ @errorText
        </div>
    }

    @if (!string.IsNullOrEmpty(successText))
    {
        <div class="alert alert-success" role="alert">
            ✅ @successText
        </div>
    }

    <div style="display: flex; gap: 10px; justify-content: center;">
        <button class="btn btn-primary" @onclick="OnClickRegister" disabled="@isLoading">
            @if (isLoading)
            {
                <span>Opretter...</span>
            }
            else
            {
                <span>Opret bruger</span>
            }
        </button>
        <a href="/login" class="btn btn-secondary">Tilbage til login</a>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string confirmPassword = "";
    private string errorText = "";
    private string successText = "";
    private bool isLoading;

    private async Task OnClickRegister()
    {
        errorText = "";
        successText = "";

        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorText = "Venligst udfyld alle felter";
            return;
        }

        if (password != confirmPassword)
        {
            errorText = "Adgangskoderne matcher ikke";
            return;
        }

        if (password.Length < 4)
        {
            errorText = "Adgangskoden skal være mindst 4 tegn";
            return;
        }

        isLoading = true;

        var newUser = await LoginService.Register(username, password);
        
        isLoading = false;

        if (newUser != null)
        {
            successText = "Bruger oprettet! Du kan nu logge ind.";
            username = "";
            password = "";
            confirmPassword = "";
            
            // Navigate to login after 2 seconds
            await Task.Delay(2000);
            Navigation.NavigateTo("/login");
        }
        else
        {
            errorText = "Brugernavnet findes allerede eller der skete en fejl";
        }
    }
}
