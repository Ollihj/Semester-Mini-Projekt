@page "/annonce/{id}"
@using Core.Models
@using BlazorApp4.Service
@inject IItemService itemService
@inject IKøbsanmodningerService KoebsService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Navigation

@if (annonce == null)
{
    <p>Henter annonce...</p>
}
else
{
    <div class="container mt-4" style="max-width:600px;">
        @if (!string.IsNullOrEmpty(annonce.billedeUrl))
        {
            <img src="@annonce.billedeUrl" class="rounded mb-3" style="width:100%; max-width:400px; height:300px; object-fit:cover;" alt="billede" />
        }

        <h2>@annonce.Titel</h2>
        <h4 class="text-success">@annonce.pris kr.</h4>

        <p><strong>Kategori:</strong> @annonce.kategori</p>
        <p><strong>Beskrivelse:</strong> @annonce.Description</p>
        <p><strong>Oprettet:</strong> @annonce.oprettet.ToShortDateString()</p>

        <span class="badge bg-success">@annonce.status</span>

        @if (annonce.status == "Aktiv"
            && currentUserId != null
            && annonce.brugerID != currentUserId)
        {
            <div class="mt-3">
                <button class="btn btn-primary"
                        @onclick="OpretKoebsanmodning">
                    Køb
                </button>
            </div>
        }
        else if (annonce.brugerID == currentUserId)
        {
            <p class="text-muted mt-3">
                Du ejer denne annonce.
            </p>
        }
        else if (annonce.status != "Aktiv")
        {
            <p class="text-muted mt-3">
                Denne annonce er ikke længere aktiv.
            </p>
        }

        <div class="mt-4">
            <button class="btn btn-secondary"
                    @onclick="GaTilbage">
                ← Tilbage
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string id { get; set; }

    private annoncer? annonce;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        annonce = await itemService.GetById(id);

        var user = await LocalStorage.GetItemAsync<bruger>("user");
        currentUserId = user?.brugerID;
    }

    private void GaTilbage()
    {
        Navigation.NavigateTo("/");
    }

    private async Task OpretKoebsanmodning()
    {
        var user = await LocalStorage.GetItemAsync<bruger>("user");

        if (user == null || string.IsNullOrEmpty(user.brugerID))
            return;

        var anmodning = new købsanmodninger
        {
            købsanmodningID = Guid.NewGuid().ToString(),
            annonceId = annonce!.annonceId,
            brugerID = user.brugerID,
            status = "Afventer",
            dato = DateTime.Now
        };

        await KoebsService.Add(anmodning);

        Navigation.NavigateTo("/mineindkøb");
    }
}
