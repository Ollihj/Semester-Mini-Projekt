@page "/mineindkøb"
@using BlazorApp4.Service
@using Core.Models
@inject IKøbsanmodningerService købsService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<h3>Mine Indkøb</h3>

@if (mineKøbsanmodninger == null)
{
    <p>Loading...</p>
}
else if (!mineKøbsanmodninger.Any())
{
    <p>Du har ingen købsanmodninger endnu.</p>
}
else
{
    <div class="row">
        @foreach (var køb in mineKøbsanmodninger)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Købsanmodning ID: @køb.købsanmodningID</h5>
                        <p class="card-text"><strong>Annonce ID:</strong> @køb.annonceId</p>
                        <p class="card-text"><strong>Status:</strong> @køb.status</p>
                        <p class="card-text"><small class="text-muted">Dato: @køb.dato.ToShortDateString()</small></p>
                        <!-- TODO: Later show actual ad details instead of just ID -->
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<købsanmodninger> mineKøbsanmodninger = new();

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await LocalStorage.GetItemAsync<bruger>("user");

        if (currentUser == null || string.IsNullOrEmpty(currentUser.brugerID))
        {
            return;
        }

        var alleKøbsanmodninger = await købsService.GetAll();
        mineKøbsanmodninger = alleKøbsanmodninger.Where(k => k.brugerID == currentUser.brugerID).ToList();
        StateHasChanged();
    }
}
