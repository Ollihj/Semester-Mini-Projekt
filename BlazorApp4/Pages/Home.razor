@page "/"
@using BlazorApp4.Service
@using Core.Models
@using Blazored.LocalStorage
@inject IItemService itemService
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage

<h3>Annoncer</h3>

<button class="btn btn-success" @onclick="VisFormular">Opret annonce</button>
<button class="btn btn-outline-secondary ms-2" @onclick="HentAnnoncer">↺ Genindlæs</button>

@if (visFormular)
{
    <div class="border p-3 mt-3">
        <h4>Opret ny annonce</h4>

        <label>Titel</label>
        <input class="form-control mb-2" @bind="nyAnnonce.Titel" />

        <label>Beskrivelse</label>
        <input class="form-control mb-2" @bind="nyAnnonce.Description" />

        <label>Pris</label>
        <input class="form-control mb-2" type="number" @bind="nyAnnonce.pris" />

        <label>Kategori</label>
        <select class="form-control mb-2" @bind="nyAnnonce.kategori">
            <option value="" disabled selected>Vælg kategori</option>
            <option value="Tøj">Tøj</option>
            <option value="Elektronik">Elektronik</option>
            <option value="Møbler">Møbler</option>
            <option value="Sportsartikler">Sportsartikler</option>
            <option value="Andet">Andet</option>
        </select>

        <label>Billede URL (valgfri)</label>
        <input class="form-control mb-2" @bind="nyAnnonce.billedeUrl" placeholder="https://..." />

        <button class="btn btn-primary" @onclick="OpretAnnonce">Opret</button>
        <button class="btn btn-secondary ms-2" @onclick="LukFormular">Annuller</button>
    </div>
}

<div class="mt-4">
    <label>Filtrer efter kategori</label>
    <select class="form-control mb-3" style="max-width:250px;" @onchange="FiltererAnnoncer">
        <option value="">Alle kategorier</option>
        <option value="Tøj">Tøj</option>
        <option value="Elektronik">Elektronik</option>
        <option value="Møbler">Møbler</option>
        <option value="Sportsartikler">Sportsartikler</option>
        <option value="Andet">Andet</option>
    </select>
</div>

<div class="row">
    @foreach (var item in filtreredeAnnoncer)
    {
        <div class="col-md-4 mb-3">
            <AnnonceItem Item="item" />
        </div>
    }
</div>

@code {
    private List<annoncer> annonceList = new();
    private List<annoncer> filtreredeAnnoncer = new();
    private annoncer nyAnnonce = new();
    private bool visFormular = false;
    private Core.Models.bruger? currentUser;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await LocalStorage.GetItemAsync<Core.Models.bruger>("user");
        if (currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await HentAnnoncer();
    }

    private async Task HentAnnoncer()
    {
        annonceList = await itemService.GetAll();
        filtreredeAnnoncer = new List<annoncer>(annonceList);
        StateHasChanged();
    }

    private void FiltererAnnoncer(ChangeEventArgs e)
    {
        var valgtKategori = e.Value?.ToString();

        if (string.IsNullOrEmpty(valgtKategori))
        {
            filtreredeAnnoncer = new List<annoncer>(annonceList);
        }
        else
        {
            filtreredeAnnoncer = annonceList.Where(a => a.kategori == valgtKategori).ToList();
        }
    }

    private void VisFormular()
    {
        visFormular = true;
    }

    private void LukFormular()
    {
        visFormular = false;
        nyAnnonce = new();
    }

    private async Task OpretAnnonce()
    {
        if (string.IsNullOrEmpty(nyAnnonce.kategori) || currentUser == null)
        {
            return;
        }

        nyAnnonce.oprettet = DateTime.Now;
        nyAnnonce.annonceId = Guid.NewGuid().ToString();
        nyAnnonce.status = "Aktiv";
        nyAnnonce.brugerID = currentUser.brugerID;

        await itemService.Add(nyAnnonce);

        LukFormular();
        await HentAnnoncer();
    }
}
