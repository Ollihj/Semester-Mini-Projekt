@page "/"
@using BlazorApp4.Service
@using Core.Models
@inject IItemService itemService

@foreach (var item in annoncer)
{
    <AnnonceItem Item="item" />
}

@code
{
    private List<annoncer> annoncer = new();

    protected override async Task OnInitializedAsync()
    {
        
      annoncer = await itemService.GetAll();
    }
}
