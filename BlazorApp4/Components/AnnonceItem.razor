@using Core.Models

@inject NavigationManager Navigation

<div class="card h-100" style="cursor:pointer;" @onclick="GaTilDetail">
    @if (!string.IsNullOrEmpty(Item.billedeUrl))
    {
        <img src="@Item.billedeUrl" class="card-img-top" style="height:200px; object-fit:cover;" alt="billede" />
    }
    <div class="card-body">
        <h5 class="card-title">@Item.Titel</h5>
        <p><strong>Pris:</strong> @Item.pris kr.</p>
        <p><strong>Kategori:</strong> @Item.kategori</p>
        <span class="badge bg-success">@Item.status</span>
    </div>
</div>

@code {
    [Parameter]
    public annoncer Item { get; set; }

    private void GaTilDetail()
    {
        Navigation.NavigateTo($"/annonce/{Item.annonceId}");
    }
}